# Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# Mode: "pipe" atau "logfile"
MODE=pipe

# Mining address
MINING_ADDRESS=keryx:your_address_here

# Path miner (untuk pipe mode)
MINER_EXECUTABLE=/root/keryx-miner/target/release/keryx-miner

# CUDA workload (intensitas GPU, coba: 256, 512, 1024)
# Makin tinggi = hashrate lebih tinggi, tapi GPU lebih panas
# RTX 4060 Ti 16GB: 1024 aman
CUDA_WORKLOAD=1024

# Path log file (untuk logfile mode)
LOG_FILE_PATH=/root/keryx-miner/miner.log

# Keryx Node JSON-RPC (dari flag --rpclisten-json)
KERYX_NODE_RPC=http://127.0.0.1:24110
